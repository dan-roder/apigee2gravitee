{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/apigee2gravitee/developers.config.schema.json",
  "title": "Developers Migration Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "gravitee",
    "roles",
    "policies",
    "capabilities",
    "productPlanMap",
    "reporting"
  ],
  "properties": {
    "gravitee": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url",
        "orgId",
        "envId"
      ],
      "properties": {
        "url": {
          "type": "string",
          "minLength": 1
        },
        "orgId": {
          "type": "string",
          "minLength": 1
        },
        "envId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "roles": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "organization",
        "environment"
      ],
      "properties": {
        "organization": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "environment": {
          "$ref": "#/$defs/nonEmptyStringArray"
        }
      }
    },
    "policies": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "inactiveDeveloper",
        "smtp",
        "defaultApplication",
        "apiKeyContinuity",
        "existingUser",
        "existingApplication",
        "userProvisioning"
      ],
      "properties": {
        "inactiveDeveloper": {
          "enum": [
            "skip",
            "import-disabled",
            "import-and-revoke"
          ]
        },
        "smtp": {
          "enum": [
            "acknowledged",
            "suppressed",
            "live"
          ]
        },
        "defaultApplication": {
          "enum": [
            "must-be-disabled",
            "allowed"
          ]
        },
        "apiKeyContinuity": {
          "enum": [
            "preserve-if-supported",
            "accept-regenerated",
            "fail-if-not-preservable"
          ]
        },
        "oauthClientContinuity": {
          "enum": [
            "preserve-if-supported",
            "accept-regenerated",
            "fail-if-not-preservable"
          ]
        },
        "existingUser": {
          "enum": [
            "match-and-reuse",
            "match-and-update",
            "fail-on-existing"
          ]
        },
        "existingApplication": {
          "enum": [
            "match-and-reuse",
            "match-and-update",
            "fail-on-existing"
          ]
        },
        "userProvisioning": {
          "enum": [
            "reuse-only",
            "reuse-or-create-silently",
            "allow-invites"
          ]
        }
      }
    },
    "productPlanMap": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          {
            "$ref": "#/$defs/productPlanTarget"
          },
          {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/productPlanTarget"
            }
          }
        ]
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "silentUserCreation",
        "apiKeyValuePreservation",
        "oauthClientValuePreservation",
        "applicationOwnership"
      ],
      "properties": {
        "silentUserCreation": {
          "enum": [
            "supported",
            "unsupported",
            "unknown"
          ]
        },
        "apiKeyValuePreservation": {
          "enum": [
            "supported",
            "unsupported",
            "unknown"
          ]
        },
        "oauthClientValuePreservation": {
          "enum": [
            "supported",
            "unsupported",
            "unknown"
          ]
        },
        "applicationOwnership": {
          "enum": [
            "direct-member",
            "metadata-only",
            "unknown"
          ]
        }
      }
    },
    "applicationNotifications": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "subscriptionAccepted": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "customFieldMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "filters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "includeDevelopers": {
          "$ref": "#/$defs/stringArray"
        },
        "excludeDevelopers": {
          "$ref": "#/$defs/stringArray"
        },
        "includeApps": {
          "$ref": "#/$defs/stringArray"
        },
        "excludeApps": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "reporting": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reportDir",
        "stateFile"
      ],
      "properties": {
        "reportDir": {
          "type": "string",
          "minLength": 1
        },
        "stateFile": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "productPlanTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targetApi",
        "targetPlan"
      ],
      "properties": {
        "targetApi": {
          "type": "string",
          "minLength": 1
        },
        "targetApiId": {
          "type": "string",
          "minLength": 1
        },
        "targetApiAliases": {
          "$ref": "#/$defs/stringArray"
        },
        "targetPlan": {
          "type": "string",
          "minLength": 1
        },
        "targetPlanId": {
          "type": "string",
          "minLength": 1
        },
        "targetPlanAliases": {
          "$ref": "#/$defs/stringArray"
        },
        "matchMode": {
          "enum": [
            "id-only",
            "exact",
            "alias"
          ]
        }
      }
    }
  }
}
